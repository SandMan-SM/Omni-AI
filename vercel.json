{
  "builds": [
    {
      "use": "@vercel/node",
      "src": "server/index.ts"
    },
    {
      "use": "@vercel/static",
      "config": {
        "source": "dist/public/**",
        "destination": ""
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "dist/public/$1"
    }
  ]
}
