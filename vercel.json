{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node",
      "config": {
        "outputDirectory": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/dist/public/$1" }
  ]
}
